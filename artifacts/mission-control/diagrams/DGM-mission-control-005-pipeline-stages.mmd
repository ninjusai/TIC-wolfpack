%% id: DGM-mission-control-005
%% type: flow
%% format: mermaid
%% traces-to: [REQ-mission-control-003]
%% author: sketch
%% last-updated: 2026-03-30

graph LR
    %% ── Pipeline Stages ──
    S1["<b>Stage 1</b><br/>Problem<br/>Framing<br/><i>Agent: Framer</i>"]
    G1{"<b>G1</b><br/>Gate<br/>Review"}
    S2["<b>Stage 2</b><br/>Eval<br/>Spec<br/><i>Agent: Evaluator</i>"]
    G2{"<b>G2</b><br/>Gate<br/>Review"}
    S3["<b>Stage 3</b><br/>PRD<br/><i>Agent: Quill</i>"]
    G3{"<b>G3</b><br/>Gate<br/>Review"}
    S4["<b>Stage 4</b><br/>Diagrams<br/><i>Agent: Sketch</i>"]
    G4{"<b>G4</b><br/>Gate<br/>Review"}
    S5["<b>Stage 5</b><br/>Build<br/>Plan<br/><i>Agent: Planner</i>"]
    G5{"<b>G5</b><br/>Final<br/>Gate"}

    %% ── Flow ──
    S1 -- "Artifact:<br/>problem.md" --> G1
    G1 -- "Pass" --> S2
    G1 -. "Fail:<br/>revision notes" .-> S1
    S2 -- "Artifact:<br/>eval-spec.md" --> G2
    G2 -- "Pass" --> S3
    G2 -. "Fail:<br/>revision notes" .-> S2
    S3 -- "Artifact:<br/>prd.md" --> G3
    G3 -- "Pass" --> S4
    G3 -. "Fail:<br/>revision notes" .-> S3
    S4 -- "Artifacts:<br/>diagrams/*.mmd" --> G4
    G4 -- "Pass" --> S5
    G4 -. "Fail:<br/>revision notes" .-> S4
    S5 -- "Artifact:<br/>build-plan.md" --> G5
    G5 -- "Pass:<br/>Ready for<br/>implementation" --> done["<b>Implementation<br/>Ready</b>"]
    G5 -. "Fail:<br/>revision notes" .-> S5

    %% ── Gate Metadata (shown in UI) ──
    %% Each gate displays: status (pending/passed/failed),
    %% attempt count, last rejection reason

    %% ── Styles ──
    classDef stage fill:#161b22,stroke:#58a6ff,color:#e6edf3
    classDef gate fill:#161b22,stroke:#d29922,color:#e6edf3
    classDef pass fill:#161b22,stroke:#3fb950,color:#e6edf3
    classDef fail fill:#161b22,stroke:#f85149,color:#e6edf3
    classDef done fill:#3fb950,stroke:#3fb950,color:#0d1117,font-weight:bold

    class S1,S2,S3,S4,S5 stage
    class G1,G2,G3,G4,G5 gate
    class done done
