{# Scrollytelling — cinematic scroll-scrubbed section #}
{% include "components/scrollytelling.njk" %}

{# Proof Strip #}
{% set proof_stats = [
  { number: "6+", label: "Brands" },
  { number: "20+", label: "Years Industry Experience" },
  { number: "QLD", label: "Queensland Wide" },
  { number: "Dedicated", label: "Operations Support" }
] %}
{% include "components/proof-strip.njk" %}

{# Value Creation — Acquire. Operate. Support. #}
<section class="section section--light" id="value-creation">
  <div class="container">
    <h2 data-animate="fade-up">Acquire. Operate. Support.</h2>
    <div class="pillar-grid" data-stagger>
      {% set pillar_number = "01" %}
      {% set pillar_title = "Acquire" %}
      {% set pillar_description = "We acquire driving school businesses with continuity and respect for owners, teams, and brand equity." %}
      {% include "components/pillar-block.njk" %}

      {% set pillar_number = "02" %}
      {% set pillar_title = "Operate" %}
      {% set pillar_description = "We operate schools better through shared systems, management, marketing, fleet, and operational standards." %}
      {% include "components/pillar-block.njk" %}

      {% set pillar_number = "03" %}
      {% set pillar_title = "Support" %}
      {% set pillar_description = "We support the wider industry with specialist services built for driving schools." %}
      {% include "components/pillar-block.njk" %}
    </div>
  </div>
</section>

{# Our Group Preview #}
<section class="section section--light" id="our-group-preview">
  <div class="container">
    <h2 data-animate="fade-up">Our Group</h2>
    <div class="brand-grid" data-stagger>
      {% for brand in collections.brands | batch(3) | first %}
        {% include "components/brand-card.njk" %}
      {% endfor %}
    </div>
    <p class="section__link" data-animate="fade-up"><a href="/our-group/" class="btn btn--secondary">View All Brands</a></p>
  </div>
</section>

{# Services Preview #}
<section class="section section--alt" id="services-preview" data-animate="fade-up">
  <div class="container">
    <h2>Services for Driving Schools</h2>
    <p>From operational systems to fleet support, TIC Group provides specialist services designed for driving school businesses. Full details coming soon.</p>
    <a href="/contact/" class="btn btn--primary">Get in Touch</a>
  </div>
</section>

