<header class="site-header" role="banner">
  <div class="container">
    <a href="/" class="site-logo" aria-label="{{ site.name }} — Home">
      <img src="/assets/images/tic-logo.png" alt="{{ site.name }}" class="site-logo__img">
    </a>
    <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>
    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul class="primary-nav__list">
        {% for item in navigation.primary %}
        <li>
          <a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
