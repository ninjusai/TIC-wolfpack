<section class="hero hero--{{ variant | default('dark') }}">
  <div class="container">
    <h1 class="hero__title">{{ hero_title }}</h1>
    {% if hero_subtitle %}
    <p class="hero__subtitle">{{ hero_subtitle }}</p>
    {% endif %}
    {% if hero_ctas %}
    <div class="hero__actions">
      {% for cta in hero_ctas %}
      <a href="{{ cta.url }}" class="btn btn--{{ cta.style | default('primary') }}">{{ cta.text }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>
